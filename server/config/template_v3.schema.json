{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dirkinstitute.local/schemas/agentic-sovereignty-template-v3.json",
  "title": "Agentic Sovereignty Template v3 Payload",
  "type": "object",
  "required": [
    "doc_title",
    "doc_subtitle",
    "doc_author",
    "doc_date",
    "doc_short_title",
    "foreword",
    "about_me",
    "introduction",
    "abbreviations_list",
    "figures_list",
    "tables_list",
    "chapters",
    "chapter_1_title",
    "chapter_1_intro",
    "chapter_1_questions",
    "chapter_1_exercise"
  ],
  "properties": {
    "doc_title": { "type": "string", "minLength": 1 },
    "doc_subtitle": { "type": "string", "minLength": 1 },
    "doc_author": { "type": "string", "minLength": 1 },
    "doc_date": { "type": "string", "minLength": 1 },
    "doc_short_title": { "type": "string", "minLength": 1 },

    "foreword": { "type": "string" },
    "about_me": { "type": "string" },
    "introduction": { "type": "string" },
    "abbreviations_list": { "type": "string" },
    "figures_list": { "type": "string" },
    "tables_list": { "type": "string" },

    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["chapter_index", "chapter_title"],
        "properties": {
          "chapter_index": { "type": ["string", "integer"] },
          "chapter_title": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },

    "chapter_1_title": { "type": "string", "minLength": 1 },
    "chapter_1_intro": { "type": "string" },
    "chapter_1_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "chapter_1_exercise": { "type": "string" }
  },
  "additionalProperties": true
}
